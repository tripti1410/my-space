		// 				if (activeId && headingMap.has(activeId)) {
		// 					headingMap.get(activeId)!.classList.remove("is-active");
		// 				}
		// 				activeId = id;
		// 				headingMap.get(id)?.classList.add("is-active");
		// 			}
		// 		});
		// 	},
		// 	{
		// 		rootMargin: "0px 0px -70% 0px",
		// 		threshold: 0,

---
const { title } = Astro.props;
const pageTitle =
	title === undefined || title.trim() === ""
		? "Trapti Rahangdale - Freelance Frontend Engineer"
		: `${title} | Trapti Rahangdale - Freelance Frontend Engineer`;
---

<title>{pageTitle}</title>
<meta
	name="description"
	content="Freelance Frontend Web UI/UX Engineer - India"
/>
<meta
	name="keywords"
	content="freelancer, frontend Engineer, UI Engineer, HTML, CSS, SVG, UI, UX, accessibility, javascript, greensock, illustrator, react, vue, animations, India"
/>

<link
	rel="alternate"
	title="Articles RSS Feed"
	type="application/rss+xml"
	href="https://www.trapti.dev/rss.xml"
/>
<link rel="icon" href="/favicon-32x32.png" type="image/png" />

<!-- Web analytics -->

<!-- Open Graph tags -->
<meta
	property="og:title"
	content={title || "Trapti Rahangdale - Freelance Frontend Engineer"}
/>
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url.href} />
<meta
	property="og:description"
	content="Freelance Frontend Web UI/UX Engineer - India"
/>
<meta
	property="og:image"
	content={new URL("/assets/kolkata/ich-1.jpg", Astro.site).href}
/>
<meta property="og:image:alt" content="" />
